  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:ital,wght@0,300;0,400;0,500;1,300&display=swap" rel="stylesheet" />
  <style>
    :root {
      --black: #0a0a0a;
      --white: #f5f2ee;
      --cream: #f0ebe3;
      --orange: #ff5c1a;
      --orange-light: #ff7a40;
      --green: #1aff8c;
      --muted: #6b6560;
      --card-bg: #131310;
      --border: rgba(255,255,255,0.08);
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    html { scroll-behavior: smooth; }

    body {
      background: var(--black);
      color: var(--white);
      font-family: 'DM Sans', sans-serif;
      font-size: 16px;
      line-height: 1.65;
      overflow-x: hidden;
    }

    /* ── NOISE OVERLAY ── */
    body::before {
      content: '';
      position: fixed; inset: 0; z-index: 0;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.65' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='1'/%3E%3C/svg%3E");
      opacity: 0.03;
      pointer-events: none;
    }

    /* ── UTILITY ── */
    .container { max-width: 860px; margin: 0 auto; padding: 0 24px; position: relative; z-index: 1; }
    .accent { color: var(--orange); }
    .green { color: var(--green); }
    .strike { text-decoration: line-through; color: var(--muted); }

    /* ── NAV ── */
    nav {
      position: sticky; top: 0; z-index: 100;
      padding: 18px 24px;
      display: flex; align-items: center; justify-content: space-between;
      background: rgba(10,10,10,0.85);
      backdrop-filter: blur(12px);
      border-bottom: 1px solid var(--border);
    }
    .logo {
      font-family: 'Syne', sans-serif;
      font-weight: 800; font-size: 1.1rem;
      letter-spacing: -0.03em;
    }
    .logo span { color: var(--orange); }
    nav a.cta-nav {
      background: var(--orange);
      color: #fff;
      font-family: 'Syne', sans-serif;
      font-weight: 700; font-size: 0.8rem;
      text-decoration: none;
      padding: 10px 20px;
      border-radius: 100px;
      letter-spacing: 0.02em;
      transition: background 0.2s, transform 0.2s;
    }
    nav a.cta-nav:hover { background: var(--orange-light); transform: scale(1.04); }

    /* ── HERO ── */
    .hero {
      min-height: 92vh;
      display: flex; flex-direction: column; justify-content: center;
      padding: 80px 24px 60px;
      position: relative; overflow: hidden;
    }
    .hero-bg {
      position: absolute; inset: 0; z-index: 0;
      background: radial-gradient(ellipse 70% 60% at 60% 40%, rgba(255,92,26,0.12) 0%, transparent 70%),
                  radial-gradient(ellipse 40% 40% at 10% 80%, rgba(26,255,140,0.05) 0%, transparent 60%);
    }
    .hero-tag {
      display: inline-block;
      background: rgba(255,92,26,0.15);
      border: 1px solid rgba(255,92,26,0.35);
      color: var(--orange);
      font-size: 0.75rem; font-weight: 600;
      letter-spacing: 0.12em; text-transform: uppercase;
      padding: 6px 14px; border-radius: 100px;
      margin-bottom: 28px;
      animation: fadeUp 0.8s ease both;
    }
    .hero h1 {
      font-family: 'Syne', sans-serif;
      font-size: clamp(2.8rem, 8vw, 5.2rem);
      font-weight: 800;
      line-height: 1.05;
      letter-spacing: -0.03em;
      animation: fadeUp 0.8s 0.1s ease both;
    }
    .hero h1 em { font-style: normal; color: var(--orange); }
    .hero-sub {
      margin-top: 22px;
      font-size: clamp(1rem, 2.5vw, 1.18rem);
      color: rgba(245,242,238,0.65);
      max-width: 560px;
      animation: fadeUp 0.8s 0.2s ease both;
    }
    .hero-cta {
      margin-top: 38px;
      display: flex; flex-wrap: wrap; gap: 14px; align-items: center;
      animation: fadeUp 0.8s 0.3s ease both;
    }
    .btn-primary {
      background: var(--orange);
      color: #fff;
      font-family: 'Syne', sans-serif;
      font-size: 1rem; font-weight: 700;
      text-decoration: none;
      padding: 16px 34px;
      border-radius: 100px;
      letter-spacing: 0.01em;
      transition: background 0.2s, transform 0.2s, box-shadow 0.2s;
      box-shadow: 0 0 0 0 rgba(255,92,26,0.4);
      display: inline-flex; align-items: center; gap: 8px;
    }
    .btn-primary:hover {
      background: var(--orange-light);
      transform: translateY(-2px);
      box-shadow: 0 8px 32px rgba(255,92,26,0.35);
    }
    .btn-primary svg { width: 18px; height: 18px; flex-shrink: 0; }
    .hero-proof {
      font-size: 0.85rem;
      color: rgba(245,242,238,0.45);
      display: flex; align-items: center; gap: 6px;
    }
    .hero-proof .dot { width: 6px; height: 6px; border-radius: 50%; background: var(--green); display: inline-block; animation: pulse 2s infinite; }

    /* ── SECTION BASE ── */
    section { padding: 90px 0; }
    .section-label {
      font-size: 0.7rem; font-weight: 700;
      letter-spacing: 0.15em; text-transform: uppercase;
      color: var(--orange); margin-bottom: 14px;
    }
    h2 {
      font-family: 'Syne', sans-serif;
      font-size: clamp(1.8rem, 5vw, 2.8rem);
      font-weight: 800; line-height: 1.1;
      letter-spacing: -0.03em;
    }
    .lead { font-size: 1.05rem; color: rgba(245,242,238,0.65); margin-top: 14px; }

    /* ── DIVIDER ── */
    .divider { border: none; border-top: 1px solid var(--border); }

    /* ── PERSONAL STORY ── */
    .story-section { background: #0f0e0c; border-top: 1px solid var(--border); border-bottom: 1px solid var(--border); }
    .story-card {
      background: var(--card-bg);
      border: 1px solid var(--border);
      border-radius: 20px;
      padding: 44px 40px;
      position: relative;
      overflow: hidden;
    }
    .story-card::before {
      content: '"';
      position: absolute; top: -20px; left: 28px;
      font-family: 'Syne', sans-serif;
      font-size: 9rem; font-weight: 800;
      color: rgba(255,92,26,0.08);
      line-height: 1;
    }
    .story-header {
      display: flex; align-items: center; gap: 16px;
      margin-bottom: 28px;
    }
    .avatar {
      width: 54px; height: 54px; border-radius: 50%;
      background: linear-gradient(135deg, var(--orange), #ff9a5c);
      display: flex; align-items: center; justify-content: center;
      font-family: 'Syne', sans-serif; font-weight: 800; font-size: 1.4rem;
      color: #fff; flex-shrink: 0;
    }
    .story-name { font-family: 'Syne', sans-serif; font-weight: 700; font-size: 1rem; }
    .story-role { font-size: 0.82rem; color: rgba(245,242,238,0.45); margin-top: 2px; }
    .story-badge {
      margin-left: auto;
      background: rgba(26,255,140,0.12);
      border: 1px solid rgba(26,255,140,0.25);
      color: var(--green);
      font-size: 0.72rem; font-weight: 600;
      letter-spacing: 0.08em; text-transform: uppercase;
      padding: 5px 12px; border-radius: 100px;
    }
    .story-text {
      font-size: 1.05rem;
      line-height: 1.8;
      color: rgba(245,242,238,0.82);
    }
    .story-text p + p { margin-top: 16px; }
    .highlight-inline {
      background: rgba(255,92,26,0.15);
      color: var(--orange);
      padding: 1px 6px; border-radius: 4px;
      font-weight: 500;
    }

    /* ── PRODUCT DESC ── */
    .product-desc-text {
      font-size: 1.1rem;
      color: rgba(245,242,238,0.75);
      max-width: 680px;
      margin-top: 20px;
      line-height: 1.8;
    }

    /* ── FEATURES GRID ── */
    .features-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
      gap: 16px;
      margin-top: 36px;
    }
    .feature-card {
      background: var(--card-bg);
      border: 1px solid var(--border);
      border-radius: 16px;
      padding: 28px 26px;
      transition: border-color 0.2s, transform 0.2s;
    }
    .feature-card:hover { border-color: rgba(255,92,26,0.35); transform: translateY(-3px); }
    .feature-icon {
      width: 44px; height: 44px; border-radius: 12px;
      background: rgba(255,92,26,0.12);
      display: flex; align-items: center; justify-content: center;
      margin-bottom: 16px; font-size: 1.3rem;
    }
    .feature-card h3 { font-family: 'Syne', sans-serif; font-size: 0.95rem; font-weight: 700; margin-bottom: 8px; }
    .feature-card p { font-size: 0.88rem; color: rgba(245,242,238,0.55); line-height: 1.6; }

    /* ── CURRICULUM ── */
    .curriculum-section { background: #0c0b09; }
    .curriculum-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
      gap: 10px;
      margin-top: 32px;
    }
    .curriculum-item {
      display: flex; align-items: flex-start; gap: 10px;
      background: var(--card-bg);
      border: 1px solid var(--border);
      border-radius: 10px;
      padding: 14px 16px;
      font-size: 0.88rem;
      font-weight: 500;
      transition: border-color 0.2s;
    }
    .curriculum-item:hover { border-color: rgba(255,92,26,0.3); }
    .curriculum-item .num {
      font-family: 'Syne', sans-serif;
      font-size: 0.7rem; font-weight: 800;
      color: var(--orange); letter-spacing: 0.05em;
      min-width: 26px; padding-top: 1px;
    }

    /* ── TESTIMONIAL ── */
    .testi-section { background: #0f0e0c; border-top: 1px solid var(--border); border-bottom: 1px solid var(--border); }
    .testi-card {
      background: var(--card-bg);
      border: 1px solid var(--border);
      border-radius: 20px;
      padding: 44px 40px;
      text-align: center;
    }
    .testi-card h2 { font-size: clamp(1.6rem, 4vw, 2.4rem); margin-bottom: 20px; }
    .testi-card p { color: rgba(245,242,238,0.65); max-width: 540px; margin: 0 auto 30px; }
    .btn-secondary {
      display: inline-flex; align-items: center; gap: 8px;
      background: transparent;
      border: 2px solid rgba(245,242,238,0.2);
      color: var(--white);
      font-family: 'Syne', sans-serif;
      font-size: 0.9rem; font-weight: 700;
      text-decoration: none;
      padding: 14px 28px; border-radius: 100px;
      transition: border-color 0.2s, background 0.2s;
    }
    .btn-secondary:hover { border-color: var(--orange); background: rgba(255,92,26,0.08); }
    .play-icon { width: 36px; height: 36px; background: var(--orange); border-radius: 50%; display: inline-flex; align-items: center; justify-content: center; flex-shrink: 0; }

    /* ── WHAT YOU GET ── */
    .benefits-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
      gap: 10px;
      margin-top: 32px;
    }
    .benefit-item {
      display: flex; align-items: flex-start; gap: 10px;
      padding: 4px 0;
      font-size: 0.9rem;
      color: rgba(245,242,238,0.8);
    }
    .benefit-item .check { color: var(--green); font-size: 1rem; flex-shrink: 0; padding-top: 1px; }

    /* ── SCHEDULE ── */
    .schedule-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
      gap: 16px;
      margin-top: 32px;
    }
    .schedule-card {
      background: var(--card-bg);
      border: 1px solid var(--border);
      border-radius: 16px;
      padding: 28px;
    }
    .schedule-card h3 {
      font-family: 'Syne', sans-serif;
      font-size: 0.85rem; font-weight: 700;
      letter-spacing: 0.08em; text-transform: uppercase;
      color: var(--orange); margin-bottom: 14px;
    }
    .schedule-item { display: flex; gap: 10px; font-size: 0.88rem; margin-bottom: 8px; color: rgba(245,242,238,0.75); }
    .schedule-item strong { color: var(--white); }

    /* ── PRICING ── */
    .pricing-section { background: #0f0e0c; border-top: 1px solid var(--border); }
    .pricing-card {
      background: var(--card-bg);
      border: 2px solid rgba(255,92,26,0.4);
      border-radius: 24px;
      padding: 52px 48px;
      text-align: center;
      position: relative;
      overflow: hidden;
      max-width: 560px;
      margin: 36px auto 0;
    }
    .pricing-card::before {
      content: '';
      position: absolute; top: 0; left: 0; right: 0; height: 3px;
      background: linear-gradient(90deg, var(--orange), var(--orange-light));
    }
    .pricing-badge {
      display: inline-block;
      background: rgba(255,92,26,0.15);
      border: 1px solid rgba(255,92,26,0.3);
      color: var(--orange);
      font-size: 0.72rem; font-weight: 700;
      letter-spacing: 0.1em; text-transform: uppercase;
      padding: 6px 14px; border-radius: 100px;
      margin-bottom: 24px;
    }
    .price-old {
      font-size: 1.3rem; color: var(--muted);
      text-decoration: line-through;
      margin-bottom: 6px;
    }
    .price-new {
      font-family: 'Syne', sans-serif;
      font-size: clamp(2.8rem, 8vw, 4rem);
      font-weight: 800;
      line-height: 1;
      color: var(--white);
      letter-spacing: -0.04em;
    }
    .price-note {
      font-size: 0.85rem;
      color: rgba(245,242,238,0.45);
      margin-top: 8px;
      margin-bottom: 32px;
    }
    .btn-cta {
      display: inline-flex; align-items: center; gap: 10px;
      background: var(--orange);
      color: #fff;
      font-family: 'Syne', sans-serif;
      font-size: 1.1rem; font-weight: 800;
      text-decoration: none;
      padding: 18px 40px;
      border-radius: 100px;
      letter-spacing: 0.01em;
      width: 100%;
      justify-content: center;
      transition: background 0.2s, transform 0.2s, box-shadow 0.3s;
      box-shadow: 0 0 40px rgba(255,92,26,0.25);
    }
    .btn-cta:hover {
      background: var(--orange-light);
      transform: translateY(-3px);
      box-shadow: 0 12px 44px rgba(255,92,26,0.4);
    }
    .security-note {
      margin-top: 18px;
      font-size: 0.8rem;
      color: rgba(245,242,238,0.35);
      display: flex; align-items: center; justify-content: center; gap: 6px;
    }

    /* ── FOOTER ── */
    footer {
      padding: 36px 24px;
      text-align: center;
      border-top: 1px solid var(--border);
      font-size: 0.82rem;
      color: rgba(245,242,238,0.3);
    }
    footer a { color: var(--orange); text-decoration: none; }
    footer a:hover { text-decoration: underline; }

    /* ── ANIMATIONS ── */
    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(24px); }
      to   { opacity: 1; transform: translateY(0); }
    }
    @keyframes pulse {
      0%, 100% { opacity: 1; }
      50%       { opacity: 0.35; }
    }

    /* ── SCROLL REVEAL ── */
    .reveal {
      opacity: 0;
      transform: translateY(28px);
      transition: opacity 0.7s ease, transform 0.7s ease;
    }
    .reveal.visible { opacity: 1; transform: translateY(0); }

    /* ── RESPONSIVE ── */
    @media (max-width: 600px) {
      .story-card { padding: 28px 22px; }
      .pricing-card { padding: 36px 24px; }
      .testi-card { padding: 28px 22px; }
      nav .cta-nav { font-size: 0.72rem; padding: 8px 14px; }
    }
  </style>
</head>
